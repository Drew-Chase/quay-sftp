{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "quay_sftp",
  "version": "0.1.0",
  "identifier": "com.github.drewchase.quay-sftp",
  "build": {
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "quay sftp",
        "minWidth": 800,
        "minHeight": 600,
        "width": 1280,
        "height": 720,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
