import { Theme } from "../themes/theme.slint";
import { Layout } from "../themes/layout.slint";

export struct TabItem {
    key: string,
    label: string,
    badge: int,
}

export enum TabVariant {
    filled,
    outlined,
    underlined
}

export enum TabColor {
    default,
    primary
}

export component Tabs inherits Rectangle {
    in property <[TabItem]> tabs;
    in property <TabVariant> variant: TabVariant.filled;
    in property <TabColor> tab-color: TabColor.default;
    in property <length> radius: Layout.radius.full;
    in-out property <int> selected-index: 0;
    in property <bool> full-width: false;
    in property <length> font-size: Layout.text.xs;
    in property <length> badge-font-size: Layout.text.xxs;
    in property <length> space: 4px;

    callback tab-selected(int);

    property <length> tab-width: 64px;
    property <length> tab-height: 28px;
    property <length> tab-padding: 4px;

    // Variant-derived spacing
    property <length> effective-padding:
        variant == TabVariant.underlined ? 0px : tab-padding;

    // Actual rendered tab width: fills container evenly when full-width
    property <length> rendered-tab-width: full-width ? (root.width - effective-padding * 2 - space * max(0, tabs.length - 1)) / max(1, tabs.length) : tab-width;

    // ── Color tokens (resolved from `tab-color` + `variant`) ──────────
    // Tint: mid-contrast accent used for outlines and underlines
    private property <color> tint:
        tab-color == TabColor.primary ? Theme.palette.accent.base : Theme.palette.ink.ink02;

    // Filled cursor fill
    private property <brush> cursor-fill:
        tab-color == TabColor.primary ? Theme.palette.accent.base : Theme.palette.hero.content.c4.bg;

    // Foreground rendered ON the filled cursor (high contrast against cursor-fill)
    private property <color> on-cursor:
        tab-color == TabColor.primary ? Theme.palette.accent.ink : Theme.palette.ink.ink01;

    // Selected text for outlined / underlined variants (no opaque cursor behind it)
    private property <brush> selected-ink:
        tab-color == TabColor.primary ? Theme.palette.accent.base : Theme.palette.ink.ink01;

    // Final selected-text: delegates to on-cursor (filled) or selected-ink (rest)
    private property <brush> selected-text:
        variant == TabVariant.filled ? on-cursor : selected-ink;

    // Unselected text (constant across all variants/colors)
    private property <brush> unselected-text: Theme.palette.ink.ink02;

    // Badge tokens (selected state)
    private property <brush> selected-badge-bg:
        variant == TabVariant.filled ? on-cursor.with-alpha(0.25) : tab-color == TabColor.primary ? Theme.palette.accent.soft : Theme.palette.surface.level3;

    private property <brush> selected-badge-fg:
        variant == TabVariant.filled ? on-cursor : selected-ink;

    // ── Container visuals ────────────────────────────────────────────
    property <brush> container-bg:
        variant == TabVariant.filled ? Theme.palette.surface.level2 : transparent;
    property <brush> container-border:
        variant == TabVariant.filled ? Theme.palette.hairline.subtle : variant == TabVariant.outlined ? Theme.palette.hairline.strong : transparent;
    property <length> container-border-width:
        variant == TabVariant.underlined ? 0px : Layout.border.thin;
    property <length> container-radius:
        variant == TabVariant.underlined ? 0px : radius;
    property <length> cursor-inner-radius:
        variant == TabVariant.underlined ? 0px : radius > effective-padding ? radius - effective-padding : 0px;

    property <length> total-width:
        effective-padding * 2 + (tab-width * tabs.length) + (space * max(0, tabs.length - 1));

    width: total-width;
    horizontal-stretch: full-width ? 1 : 0;
    height: variant == TabVariant.underlined ? tab-height : tab-height + (effective-padding * 2);
    border-radius: container-radius;
    background: container-bg;
    border-color: container-border;
    border-width: container-border-width;

    // ── Sliding cursor (filled / outlined) ───────────────────────────
    if variant == TabVariant.filled || variant == TabVariant.outlined: Rectangle {
        x: root.effective-padding + (root.rendered-tab-width + root.space) * root.selected-index;
        y: root.effective-padding;
        width: root.rendered-tab-width;
        height: root.tab-height;
        border-radius: root.cursor-inner-radius;
        background: root.variant == TabVariant.filled ? root.cursor-fill : transparent;
        border-color: root.variant == TabVariant.outlined ? root.tint : transparent;
        border-width: root.variant == TabVariant.outlined ? Layout.border.thin : 0px;

        animate x {
            duration: Layout.duration.normal;
            easing: ease-in-out;
        }
    }

    // ── Underline cursor ─────────────────────────────────────────────
    if variant == TabVariant.underlined: Rectangle {
        x: (root.rendered-tab-width + root.space) * root.selected-index;
        y: root.tab-height - 2px;
        width: root.rendered-tab-width;
        height: 2px;
        background: root.selected-ink;
        border-radius: 1px;

        animate x {
            duration: Layout.duration.normal;
            easing: ease-in-out;
        }
    }

    // ── Bottom hairline for underlined variant ───────────────────────
    if variant == TabVariant.underlined: Rectangle {
        x: 0;
        y: root.tab-height - 1px;
        width: root.width;
        height: 1px;
        background: Theme.palette.hairline.subtle;
    }

    // ── Tab labels ───────────────────────────────────────────────────
    for tab[i] in root.tabs: Rectangle {
        x: root.effective-padding + (root.rendered-tab-width + root.space) * i;
        y: root.variant == TabVariant.underlined ? 0px : root.effective-padding;
        width: root.rendered-tab-width;
        height: root.tab-height;

        HorizontalLayout {
            alignment: center;
            spacing: 18px;

            Text {
                text: tab.label;
                font-family: Layout.font.sans;
                font-size: font-size;
                font-weight: Layout.weight.medium;
                vertical-alignment: center;
                color: root.selected-index == i ? root.selected-text : root.unselected-text;

                animate color { duration: Layout.duration.fast; }
            }

            // Badge
            if tab.badge > 0: VerticalLayout {
                alignment: center;
                Rectangle {
                    width: badge-text.width + 8px;
                    height: 16px;
                    border-radius: Layout.radius.full;
                    background: root.selected-index == i ? root.selected-badge-bg : Theme.palette.surface.level3;

                    animate background { duration: Layout.duration.fast; }

                    badge-text := Text {
                        text: tab.badge;
                        font-family: Layout.font.sans;
                        font-size: badge-font-size;
                        font-weight: Layout.weight.semibold;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        color: root.selected-index == i ? root.selected-badge-fg : Theme.palette.ink.ink03;

                        animate color { duration: Layout.duration.fast; }
                    }
                }
            }
        }

        TouchArea {
            mouse-cursor: MouseCursor.pointer;
            clicked => {
                root.selected-index = i;
                root.tab-selected(i);
            }
        }
    }
}
