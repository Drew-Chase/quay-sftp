import { Tabs, TabVariant, TabColor, TabItem } from "../Tabs.slint";
import { ScrollView } from "std-widgets.slint";
import { ConnectionItem, ConnectionType, Tags } from "ConnectionItem.slint";
export component ConnectionsList {
    vertical-stretch: 3;
