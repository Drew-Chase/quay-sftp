import { Layout } from "../../themes/layout.slint";
import { Theme } from "../../themes/theme.slint";
import { Tabs, TabVariant } from "../Tabs.slint";
import { Input } from "../Input.slint";
import { Icons } from "../../icons.slint";
import {
    Button,
    Color as ButtonColor,
    Size as ButtonSize,
    Variant as ButtonVariant,
} from "../Button.slint";
import { ScrollView } from "std-widgets.slint";

export component NewConnectionForm inherits Rectangle {
    property <int> selected-protocol;
    property <bool> show-advanced:false;
    border-radius: Layout.radius.lg;
    background: Theme.palette.surface.level1;
    border-color: Theme.palette.hairline.strong;
    border-width: 1px;
    drop-shadow-color: Theme.palette.surface.base;
    drop-shadow-blur: 20px;
    width: 50%;
    max-width: 900px;
    height: show-advanced ? 600px : 400px;
    clip: true;

    animate height { duration: 200ms; }

    VerticalLayout {
        padding: 1rem;
        spacing: 16px;

        // Form Header
        HorizontalLayout {
            VerticalLayout {
                alignment: center;
                Text {
                    text: "QUICK CONNECT";
                    font-size: Layout.text.sm;
                    color: Theme.palette.ink.ink03;
                }
            }

            Tabs {
                tabs: [
                    { key: "sftp", label: "SFTP" },
                    { key: "ftp", label: "FTP" },
                    { key: "s3", label: "S3" },
                ];
                selected-index <=> selected-protocol;
                tab-selected(i) => { /* handle selection */ }
            }
        }

        // Form Body
        ScrollView {
            VerticalLayout {
                spacing: 16px;
                vertical-stretch: 1;
                Input {
                    label: "HOST";
                    required: true;
                    placeholder: "user@hostname or hostname";
                }

                HorizontalLayout {
                    spacing: 12px;
                    Input {
                        label: "USERNAME";
                        required: true;
                        placeholder: "root";
                    }

                    Input {
                        label: "PORT";
                        placeholder: "22";
                    }
                }

                Input {
                    label: "REMOTE PATH";
                    placeholder: "/home/";
                }

                TouchArea {
                    mouse-cursor: MouseCursor.pointer;
                    clicked => {
                        show-advanced = !show-advanced;
                    }
                    HorizontalLayout {
                        padding-top: 10px;
                        padding-bottom: 10px;
                        padding-left: 10px;
                        Text {
                            text: "ADVANCED";
                            font-size: Layout.text.xxs;
                            color: Theme.palette.ink.ink02;
                        }

                        Image {
                            source: Icons.chevron;
                            width: 16px;
                            height: 16px;
                            colorize: Theme.palette.ink.ink04;
                            transform-rotation: show-advanced ? 0deg : 90deg;
                            animate transform-rotation { duration: 200ms; }
                        }
                    }
                }

                if show-advanced:VerticalLayout {
                    spacing: 16px;
                    width: root.width - 60px;
                    HorizontalLayout {
                        Input {
                            label: "CONNECTION NAME";
                            placeholder: "e.g. Production - web-01";
                        }
                    }

                    Rectangle {
                        background: Theme.palette.surface.level0;
                        border-color: Theme.palette.hairline.subtle;
                        border-width: 1px;
                        border-radius: Layout.radius.xl;
                        width: root.width - 50px;
                        VerticalLayout {
                            padding: 16px;
                            padding-bottom: 20px;
                            spacing: 16px;
                            HorizontalLayout {
                                spacing: 8px;
                                Image {
                                    source: Icons.lock;
                                    width: 12px;
                                    height: 12px;
                                    colorize: Theme.palette.ink.ink04;
                                }

                                Text {
                                    text: "AUTHENTICATION";
                                    font-size: Layout.text.xxs;
                                    color: Theme.palette.ink.ink03;
                                }
                            }

                            Tabs {
                                variant: TabVariant.filled;
                                radius: Layout.radius.xl;
                                full-width: true;
                                width: root.width - 80px;
                                x: 10px;
                                tabs: [
                                    { key: "keyfile", label: "Key File" },
                                    { key: "password", label: "Password" },
                                    { key: "ssh-agent", label: "SSH agent" }
                                ];
                            }

                            Input {
                                label: "PRIVATE KEY FILE";
                                placeholder: "~/.ssh/id_ed25519";
                                start-icon: Icons.key;
                            }

                            Input {
                                label: "PASSPHRASE";
                                placeholder: "Leave blank if none";
                            }
                        }
                    }

                    Rectangle {
                        background: Theme.palette.surface.level0;
                        border-color: Theme.palette.hairline.subtle;
                        border-width: 1px;
                        border-radius: Layout.radius.xl;
                        width: root.width - 50px;
                        VerticalLayout {
                            padding: 16px;
                            padding-bottom: 20px;
                            spacing: 16px;
                            HorizontalLayout {
                                spacing: 8px;
                                Image {
                                    source: Icons.network;
                                    width: 12px;
                                    height: 12px;
                                    colorize: Theme.palette.ink.ink04;
                                }

                                Text {
                                    text: "CONECTION";
                                    font-size: Layout.text.xxs;
                                    color: Theme.palette.ink.ink03;
                                }
                            }

                            HorizontalLayout {
                                spacing: 10px;
                                Input {
                                    label: "JUMP HOST";
                                    placeholder: "jumphost.example.com";
                                }

                                Input {
                                    label: "KEEP ALIVE";
                                    placeholder: "30";
                                }
                            }
                        }
                    }
                }
            }
        }

        // Form Footer
        HorizontalLayout {
            spacing: 8px;
            Button {
                text: "Connect";
                color: ButtonColor.primary;
                start-icon: Icons.key;
            }

            Button {
                text: "Save & Connect";
                start-icon: Icons.plus;
            }
            // Spacer
            Rectangle {
                horizontal-stretch: 1;
            }

            Button {
                text: "Import .ssh/config";
                start-icon: Icons.upload;
                variant: ButtonVariant.light;
            }
        }
    }
}
