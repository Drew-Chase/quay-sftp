import { Layout } from "../../themes/layout.slint";
import { Theme } from "../../themes/theme.slint";
import { FloatingLogo } from "FloatingLogo.slint";
import { ApplicationState } from "../../application_state.slint";
export component ApplicationSplash {
    max-width: 26rem;
    VerticalLayout {
        x: 10px;
        y: 50px;
        FloatingLogo { }

        Text {
            text: "Quay";
            font-size: Layout.text.display;
            font-weight: Layout.weight.bold;
            height: 75px;
            Rectangle {
                width: 10px;
                height: 10px;
                background: Theme.palette.hero.primary.base;
                border-radius: 100px;
                x: 145px;
                y: 50px;
            }
        }

        VerticalLayout {
            height: 50px;
            spacing: 5px;
            Text {
                text: "A modern SFTP, FTP, and cloud storage explorer";
                font-size: Layout.text.lg;
                color: Theme.palette.ink.ink03;
                wrap: TextWrap.word-wrap;
                letter-spacing: Layout.tracking.wide;
            }

            Text {
                text: "with a built-in shell and code editor — designed";
                font-size: Layout.text.lg;
                color: Theme.palette.ink.ink03;
                wrap: TextWrap.word-wrap;
                letter-spacing: Layout.tracking.wide;
            }

            Text {
                text: "for keyboards, made for the dark.";
                font-size: Layout.text.lg;
                color: Theme.palette.ink.ink03;
                wrap: TextWrap.word-wrap;
                letter-spacing: Layout.tracking.wide;
            }
        }

        HorizontalLayout {
            padding-top: 2rem;
            height: 3.5rem;
            spacing: 10px;
            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 5px;
                    height: 5px;
                    border-radius: 100px;
                    background: Theme.palette.semantic.ok;
                }
            }

            TouchArea {
                width: 70px;
                mouse-cursor: MouseCursor.pointer;
                Text {
                    text: "No Updates";
                    color: Theme.palette.ink.ink03;
                    font-size: Layout.text.sm;
                    font-family: Layout.font.mono;
                }
            }

            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 4px;
                    height: 4px;
                    border-radius: 100px;
                    background: Theme.palette.accent.glow;
                }
            }

            Text {
                text: "v\{ApplicationState.version}";
                color: Theme.palette.ink.ink03;
                font-size: Layout.text.sm;
                font-family: Layout.font.mono;
            }
        }
    }
}
