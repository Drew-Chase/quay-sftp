
import { Layout } from "../themes/layout.slint";
import { Theme } from "../themes/theme.slint";
export component Input {
    in property <string> label;
    in property <string> placeholder;
    in property <string> description;
    in property <bool> required: false;
    in-out property <string> value: "";
    in property <image> start-icon;
    in property <image> end-icon;

    private property <bool> has-start-icon: start-icon.width > 0 && start-icon.height > 0;
    private property <bool> has-end-icon: end-icon.width > 0 && end-icon.height > 0;
    private property <length> scroll-offset: 0;

    VerticalLayout {
        spacing: 5px;

        if label != "": HorizontalLayout {
            spacing: 2px;
            Text {
                text: label;
                font-size: Layout.text.xxs;
                color: Theme.palette.ink.ink03;
            }

            if required: Text {
                text: "*";
                font-size: Layout.text.xxs;
                color: Theme.palette.semantic.danger;
            }
        }

        container := Rectangle {
            background: Theme.palette.surface.level2;
            border-width: 1px;
            border-color: Theme.palette.hairline.strong;
            border-radius: Layout.radius.lg;
            height: 36px;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                spacing: 8px;

                if has-start-icon: VerticalLayout {
                    alignment: center;
                    Image {
                        source: start-icon;
                        width: 16px;
                        height: 16px;
                        colorize: Theme.palette.ink.ink04;
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                    min-width: 0;
                    preferred-width: 0px;
                    clip: true;

                    if value == "": Text {
                        text: placeholder;
                        font-size: Layout.text.sm;
                        color: Theme.palette.ink.ink04;
                        vertical-alignment: center;
                        height: 100%;
                        width: 100%;
                    }

                    input-comp := TextInput {
                        x: root.scroll-offset;
                        width: max(parent.width, 100000px);
                        font-size: Layout.text.sm;
                        color: Theme.palette.ink.ink01;
                        vertical-alignment: center;
                        height: 100%;
                        text <=> root.value;
                        single-line: true;
                        cursor-position-changed(pos) => {
                            if (pos.x + root.scroll-offset > parent.width) {
                                root.scroll-offset = parent.width - pos.x;
                            }
                            if (pos.x + root.scroll-offset < 0px) {
                                root.scroll-offset = -pos.x;
                            }
                            if (root.scroll-offset > 0px) {
                                root.scroll-offset = 0px;
                            }
                        }
                    }
                }

                if has-end-icon: VerticalLayout {
                    alignment: center;
                    Image {
                        source: end-icon;
                        width: 16px;
                        height: 16px;
                        colorize: Theme.palette.ink.ink04;
                    }
                }
            }
        }

        if description != "": Text {
            text: description;
            font-size: Layout.text.xxs;
            color: Theme.palette.ink.ink03;
            font-family: Layout.font.mono;
        }
    }
}
