import { Layout } from "../themes/layout.slint";
import { Theme } from "../themes/theme.slint";

export enum ButtonVariant{
    solid,
    light,
    bordered,
    ghost,
    faded
}

export enum ButtonColor{
    default,
    primary
}

export enum ButtonSize{
    sm,
    md,
    lg
}

export component Button inherits TouchArea {
    // variables
    in property <length> radius: Layout.radius.lg;
    in property <length> font-size: Layout.text.base;
    in property <int> font-weight: Layout.weight.normal;
    in property <string> font-family: Layout.font.sans;
    in property <string> text: "";
    in-out property <bool> is_hovering: false;
    in property <image> start-icon;
    in property <image> end-icon;
    in property <ButtonColor> color: ButtonColor.default;
    in property <ButtonSize> size: ButtonSize.md;
    in property <ButtonVariant> variant: ButtonVariant.solid;
    in property <image> icon;
    property <bool> icon-only:icon.width > 0 && icon.height > 0;

    // Base color tokens (resolved from `color` property)
    private property <color> tint: color == ButtonColor.primary ? Theme.palette.hero.primary.base : Theme.palette.ink.ink02;
    private property <brush> on-solid: color == ButtonColor.primary ? Theme.palette.hero.primary.fg : Theme.palette.ink.ink01;
    private property <brush> solid-bg: color == ButtonColor.primary ? Theme.palette.hero.primary.base : Theme.palette.hero.content.c3.bg;
    private property <brush> solid-hover-bg: color == ButtonColor.primary ? Theme.palette.hero.primary.c600 : Theme.palette.hero.content.c2.bg;
    private property <brush> light-hover-bg: color == ButtonColor.primary ? Theme.palette.hero.primary.c200 : Theme.palette.hero.content.c3.bg;

    // ButtonVariant-resolved background
    private property <brush> resolved-bg:
        variant == ButtonVariant.solid ? solid-bg : variant == ButtonVariant.faded ? tint.with-alpha(0.2) : transparent;

    private property <brush> resolved-bg-hover:
        variant == ButtonVariant.solid ? solid-hover-bg : variant == ButtonVariant.light ? light-hover-bg : variant == ButtonVariant.ghost ? solid-bg : variant == ButtonVariant.faded ? tint.with-alpha(0.3) : transparent;

    // ButtonVariant-resolved foreground
    private property <brush> resolved-fg:
        variant == ButtonVariant.solid ? on-solid : variant == ButtonVariant.bordered || variant == ButtonVariant.ghost ? tint : color == ButtonColor.primary ? tint : on-solid;

    private property <brush> resolved-fg-hover:
        variant == ButtonVariant.ghost ? on-solid : resolved-fg;

    // Border (only bordered + ghost)
    private property <length> resolved-border-width:
        variant == ButtonVariant.bordered || variant == ButtonVariant.ghost ? Layout.border.thin : 0px;

    // Default values
    mouse-cursor: MouseCursor.pointer;
    height: size == ButtonSize.sm ? 24px : size == ButtonSize.md ? 32px : 48px;

    Rectangle {
        background: root.has-hover ? resolved-bg-hover : resolved-bg;
        border-radius: radius;
        border-width: resolved-border-width;
        border-color: tint;
        animate background { duration: 100ms; }

        VerticalLayout {
            padding-right: 10px;
            padding-left: 10px;
            alignment: center;

            HorizontalLayout {
                spacing: 10px;
                alignment: center;

                if start-icon.width > 0 && start-icon.height > 0: VerticalLayout {
                    alignment: center;
                    Image {
                        source: start-icon;
                        width: font-size;
                        height: font-size;
                        vertical-stretch: 0;
                        colorize: root.has-hover ? resolved-fg-hover : resolved-fg;
                        animate colorize { duration: 100ms; }
                    }
                }

                if !icon-only:
                Text {
                    text: text;
                    color: root.has-hover ? resolved-fg-hover : resolved-fg;
                    font-size: font-size;
                    font-weight: font-weight;
                    font-family: font-family;
                    animate color { duration: 100ms; }
                }

                if icon-only:Image {
                    source: icon;
                    colorize: root.has-hover ? resolved-fg-hover : resolved-fg;
                    width: font-size;
                    height: font-size;

                }

                if end-icon.width > 0 && end-icon.height > 0: VerticalLayout {
                    alignment: center;
                    Image {
                        source: end-icon;
                        width: font-size;
                        height: font-size;
                        vertical-stretch: 0;
                        colorize: root.has-hover ? resolved-fg-hover : resolved-fg;
                        animate colorize { duration: 100ms; }
                    }
                }
            }
        }
    }
}
