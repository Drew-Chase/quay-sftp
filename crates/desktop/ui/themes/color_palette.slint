// ─── Color Palette Structs ──────────────────────────────────────────────────
// Mirrors the color tokens defined in tailwind.config.js / styles.css :root.
// This file defines the shape (contract) only — no values live here.
// Values are provided by dark.slint / light.slint via the Theme global.
//
// oklch → sRGB conversions are anchored on the HeroUI plugin values where
// exact matches exist, and perceptually extrapolated for the remainder.

// ─── App canvas + elevation ──────────────────────────────────────────────────
export struct SurfaceColors {
    base:   color,   // bg         #000000
    level0: color,   // surface.0  #050505
    level1: color,   // surface.1  #0b0b0c
    level2: color,   // surface.2  #131316
    level3: color,   // surface.3  #1a1a1e
    level4: color,   // content4   #242429
}

// ─── Text / ink ramp (high → low contrast) ───────────────────────────────────
export struct InkColors {
    primary:   color,   // ink.1 / foreground  #f6f7f9
    secondary: color,   // ink.2               #aeb1b8
    tertiary:  color,   // ink.3               #6b6e76
    disabled:  color,   // ink.4               #45474d
}

// ─── Hairlines (borders, dividers — NOT for text) ────────────────────────────
export struct HairlineColors {
    subtle: color,   // rgba(255,255,255,0.06)  #ffffff0f
    strong: color,   // rgba(255,255,255,0.12)  #ffffff1f
}

// ─── Brand accent (sky-blue) ─────────────────────────────────────────────────
export struct AccentColors {
    base: color,   // oklch(0.78 0.15 230)        → #21c8ff
    soft: color,   // oklch(0.78 0.15 230 / 0.16) → #21c8ff29
    glow: color,   // oklch(0.78 0.15 230 / 0.35) → #21c8ff59
    ink:  color,   // #001a2c — text rendered on accent background
}

// ─── Semantic status colors ───────────────────────────────────────────────────
export struct SemanticColors {
    ok:     color,   // oklch(0.78 0.15 155) → #59d38c
    warn:   color,   // oklch(0.82 0.15  80) → #f7b83d
    danger: color,   // oklch(0.74 0.17   5) → #ff5f5b
    violet: color,   // oklch(0.72 0.18 295) → #ae89ff
    pink:   color,   // oklch(0.74 0.17   5) → #ff5f5b
}

// ─── Tag pills (prod / stag / dev) ───────────────────────────────────────────
export struct TagSwatch {
    bg:     color,
    border: color,
    fg:     color,
}

export struct TagColors {
    prod: TagSwatch,   // red-orange hue  — oklch(…25)
    stag: TagSwatch,   // yellow hue      — oklch(…80)
    dev:  TagSwatch,   // green hue       — oklch(…155)
}

// ─── File-type icon swatches ─────────────────────────────────────────────────
export struct FiletypeSwatch {
    bg: color,
    fg: color,
}

export struct FiletypeFolderSwatch {
    gradient-from: color,   // oklch(0.32 0.10 230) → #0d2c40
    gradient-to:   color,   // oklch(0.18 0.05 230) → #091520
    fg:            color,   // oklch(0.85 0.15 230) → #7ad4f8
}

export struct FiletypeColors {
    folder: FiletypeFolderSwatch,
    js:     FiletypeSwatch,   // hue  90 — yellow
    ts:     FiletypeSwatch,   // hue 240 — blue
    py:     FiletypeSwatch,   // hue 155 — green
    rb:     FiletypeSwatch,   // hue  25 — orange
    json:   FiletypeSwatch,   // hue  50 — muted yellow
    img:    FiletypeSwatch,   // hue 295 — purple
    zip:    FiletypeSwatch,   // hue  60 — muted yellow-green
    env:    FiletypeSwatch,   // hue   0 — red
    yml:    FiletypeSwatch,   // hue   5 — red
    sh:     FiletypeSwatch,   // hue 130 — muted green
    sql:    FiletypeSwatch,   // hue 270 — muted purple
}

// ─── Code syntax highlighting tokens ─────────────────────────────────────────
export struct SyntaxColors {
    keyword:      color,   // oklch(0.78 0.18 295) → #c0a0ff
    func:         color,   // oklch(0.85 0.15 230) → #80d8fa
    string-lit:   color,   // oklch(0.85 0.15  90) → #d8cc60
    number:       color,   // oklch(0.85 0.15  25) → #ffb870
    comment:      color,   // #45474d
    operator:     color,   // #aeb1b8
    prop:         color,   // oklch(0.85 0.15 155) → #70e8a8
    typename:     color,   // oklch(0.85 0.15 230) → #80d8fa  (same as func)
    tag:          color,   // oklch(0.80 0.18   5) → #e87878
}

// ─── macOS traffic-light buttons ─────────────────────────────────────────────
export struct TrafficColors {
    red:    color,   // #ff5f57
    yellow: color,   // #febc2e
    green:  color,   // #28c840
}

// ─── HeroUI content layers (content1–content4) ───────────────────────────────
export struct ContentSwatch {
    bg: color,
    fg: color,
}

export struct ContentColors {
    c1: ContentSwatch,
    c2: ContentSwatch,
    c3: ContentSwatch,
    c4: ContentSwatch,
}

// ─── Full 50–900 color scale ──────────────────────────────────────────────────
export struct ColorScale {
    base: color,   // DEFAULT
    fg:   color,   // foreground text rendered on base
    c50:  color,
    c100: color,
    c200: color,
    c300: color,
    c400: color,
    c500: color,
    c600: color,
    c700: color,
    c800: color,
    c900: color,
}

// ─── Simple bg+fg swatch (secondary, success, warning, danger) ────────────────
export struct UiSwatch {
    base: color,
    fg:   color,
}

// ─── HeroUI semantic UI colors ────────────────────────────────────────────────
export struct HeroColors {
    background: color,
    foreground: color,
    focus:      color,
    divider:    color,
    content:    ContentColors,
    neutral:    ColorScale,   // heroui "default" scale — grayscale ramp
    primary:    ColorScale,   // brand accent with full shade range
    secondary:  UiSwatch,
    success:    UiSwatch,
    warning:    UiSwatch,
    danger:     UiSwatch,
}

// ─── Root palette — compose all token groups ─────────────────────────────────
export struct ColorPalette {
    surface:  SurfaceColors,
    ink:      InkColors,
    hairline: HairlineColors,
    accent:   AccentColors,
    semantic: SemanticColors,
    tag:      TagColors,
    filetype: FiletypeColors,
    syntax:   SyntaxColors,
    traffic:  TrafficColors,
    hero:     HeroColors,
}
