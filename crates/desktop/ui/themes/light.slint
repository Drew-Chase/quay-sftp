import {
    ColorPalette,
    SurfaceColors, InkColors, HairlineColors,
    AccentColors, SemanticColors,
    TagColors, TagSwatch,
    FiletypeColors, FiletypeSwatch, FiletypeFolderSwatch,
    SyntaxColors, TrafficColors,
    HeroColors, ContentColors, ContentSwatch, ColorScale, UiSwatch,
} from "color_palette.slint";

// ─── Light Theme ──────────────────────────────────────────────────────────────
// Derived from the same token system as DarkTheme. Key adaptations:
//
//   Surfaces  — inverted: white base, stepping darker with each elevation level
//   Ink       — inverted: near-black primary stepping toward lighter disabled
//   Hairlines — dark-on-light: rgba(0,0,0,…) instead of rgba(255,255,255,…)
//   Accent    — #21c8ff (L=0.78) has ~1.4:1 contrast on white; dropped to
//               primary.800 (#007eb7, L≈0.49) which hits ~5:1 on white
//   Semantic  — same hues, darkened one stop for ≥4.5:1 contrast on light bg
//   Filetype  — pastel bg + dark fg (inverted from dark theme's dark bg + bright fg)
//   Syntax    — all darkened to maintain readability on light surfaces
//   Traffic   — brand-locked, identical to dark theme
export global LightTheme {
    out property <ColorPalette> palette: {
        // ── Canvas + elevation ────────────────────────────────────────────────
        surface: {
            base:   #ffffff,   // bg
            level0: #fafafa,   // surface.0 equivalent
            level1: #f4f4f6,   // surface.1 equivalent
            level2: #ebebed,   // surface.2 equivalent
            level3: #e0e1e5,   // surface.3 equivalent
            level4: #d4d5da,   // content4 equivalent
        },

        // ── Text ramp ─────────────────────────────────────────────────────────
        ink: {
            primary:   #0f0f14,   // near-black
            secondary: #4a4d58,   // dark gray
            tertiary:  #7c7f8a,   // mid gray
            disabled:  #b0b3bc,   // light gray
        },

        // ── Hairlines / dividers ──────────────────────────────────────────────
        hairline: {
            subtle: #0000000f,   // rgba(0,0,0,0.06)
            strong: #0000001f,   // rgba(0,0,0,0.12)
        },

        // ── Brand accent — darkened sky blue ──────────────────────────────────
        // #21c8ff (L=0.78) fails contrast on white; heroui primary.800 (#007eb7)
        // gives ~5:1 on #ffffff while preserving the cerulean identity.
        accent: {
            base: #007eb7,   // heroui primary.800
            soft: #007eb71f, // 12% alpha on light surface
            glow: #007eb740, // 25% alpha on light surface
            ink:  #ffffff,   // white text on accent bg
        },

        // ── Semantic status ───────────────────────────────────────────────────
        // Darkened one perceptual stop from dark-theme values for contrast.
        semantic: {
            ok:     #1a7a48,   // darkened ok    — WCAG AA on white
            warn:   #9a6200,   // darkened warn  — WCAG AA on white
            danger: #c02020,   // darkened danger — WCAG AA on white
            violet: #6030c0,   // darkened violet — WCAG AA on white
            pink:   #c02040,   // darkened pink   — WCAG AA on white
        },

        // ── Environment tag pills ─────────────────────────────────────────────
        // Light pastel bg + mid-tone border + dark fg (inverted from dark theme)
        tag: {
            prod: { bg: #fff0ec, border: #f0a070, fg: #c03010 },   // red-orange
            stag: { bg: #fffff0, border: #d0b030, fg: #7a5800 },   // yellow
            dev:  { bg: #ecfff5, border: #40b060, fg: #006030 },   // green
        },

        // ── File-type icon swatches ───────────────────────────────────────────
        // Pastel bg + dark fg — exact inverse of the dark theme's
        // dark-bg + bright-fg pattern.
        filetype: {
            folder: { gradient-from: #cce8f8, gradient-to: #e8f5fc, fg: #005f8a },   // hue 230
            js:     { bg: #fffae0, fg: #6b5a00 },   // hue  90 — yellow
            ts:     { bg: #eaf0ff, fg: #1a3890 },   // hue 240 — blue
            py:     { bg: #eafff4, fg: #006a38 },   // hue 155 — green
            rb:     { bg: #fff4ea, fg: #8a3010 },   // hue  25 — orange
            json:   { bg: #fffde8, fg: #605800 },   // hue  50 — muted yellow
            img:    { bg: #f8eaff, fg: #5c1a98 },   // hue 295 — purple
            zip:    { bg: #fffdea, fg: #606800 },   // hue  60 — muted yellow-green
            env:    { bg: #ffecec, fg: #8a1010 },   // hue   0 — red
            yml:    { bg: #ffecf0, fg: #8a1014 },   // hue   5 — red
            sh:     { bg: #eeffee, fg: #1a6a1a },   // hue 130 — muted green
            sql:    { bg: #f0eeff, fg: #30188a },   // hue 270 — muted purple
        },

        // ── Syntax highlighting ───────────────────────────────────────────────
        // Same hue identity as dark theme; darkened for contrast on light bg.
        syntax: {
            keyword:    #7020b0,   // dark violet      (was #c0a0ff)
            func:       #0070a8,   // dark sky blue    (was #7ad4f8)
            string-lit: #8b6f00,   // dark yellow      (was #d8cc60)
            number:     #b04810,   // dark orange      (was #ffb870)
            comment:    #7c7f8a,   // tertiary ink     (was #45474d — too dark on light)
            operator:   #4a4d58,   // secondary ink    (was #aeb1b8 — too light on white)
            prop:       #1a7848,   // dark green       (was #70e8a8)
            typename:   #0070a8,   // dark sky blue    (same as func)
            tag:        #b01020,   // dark red/pink    (was #e87878)
        },

        // ── macOS traffic lights ──────────────────────────────────────────────
        // Brand-locked — identical to dark theme.
        traffic: {
            red:    #ff5f57,
            yellow: #febc2e,
            green:  #28c840,
        },

        // ── HeroUI semantic colors ────────────────────────────────────────────
        // Derived from dark values: surfaces inverted, accent darkened to
        // primary.800, semantic colors darkened for WCAG AA on white.
        hero: {
            background: #ffffff,
            foreground: #0f0f14,
            focus:      #007eb7,     // primary.800 — sufficient contrast on white
            divider:    #0000000f,   // rgba(0,0,0,0.06)

            content: {
                c1: { bg: #f4f4f6, fg: #0f0f14 },   // content1 equivalent
                c2: { bg: #ebebed, fg: #4a4d58 },   // content2 equivalent
                c3: { bg: #e0e1e5, fg: #7c7f8a },   // content3 equivalent
                c4: { bg: #d4d5da, fg: #b0b3bc },   // content4 equivalent
            },

            neutral: {
                base: #f4f4f6,   // default.DEFAULT (lightest surface)
                fg:   #0f0f14,   // default.foreground
                c50:  #f6f7f9,   // lightest — mirrors dark 900 inverted
                c100: #ebebed,
                c200: #d4d5da,
                c300: #b0b3bc,
                c400: #7c7f8a,
                c500: #4a4d58,
                c600: #2a2d38,
                c700: #1a1d28,
                c800: #0f1020,
                c900: #050510,   // darkest
            },

            primary: {
                base: #007eb7,   // primary.800 — contrast-safe on white
                fg:   #ffffff,
                c50:  #e8f5fc,   // lightest sky tint
                c100: #cce8f8,
                c200: #a0d8f5,
                c300: #70c4f0,
                c400: #3aaae0,
                c500: #007eb7,
                c600: #006090,
                c700: #004870,
                c800: #003050,
                c900: #001830,   // darkest
            },

            secondary: { base: #6030c0, fg: #ffffff },   // darkened violet
            success:   { base: #1a7a48, fg: #ffffff },   // darkened green
            warning:   { base: #9a6200, fg: #ffffff },   // darkened amber
            danger:    { base: #c02020, fg: #ffffff },   // darkened red
        },
    };
}
