import "..\..\fonts\inter\Inter-ThinItalic.ttf";

// ─── Layout Tokens ──────────────────────────────────────────────────────────
// Theme-independent design tokens migrated from tailwind.config.js.
// These values are shared across all themes (dark / light) — they define
// the spatial, typographic, and temporal skeleton of the UI.

// ─── Font families ───────────────────────────────────────────────────────────
export struct FontFamilies {
    sans: string,   // "Inter"
    mono: string,   // "JetBrains Mono"
}

// ─── Font sizes ──────────────────────────────────────────────────────────────
// Tuned for an IDE — body text is 12–13px, not the web-standard 14–16px.
// Each entry corresponds to one tailwind fontSize key.
export struct FontSizes {
    xxs:      length,   //  10px   — micro labels, uppercase eyebrows, kbd, status bar
    micro:    length,   //  10.5px — micro labels
    xs:       length,   //  11px   — table cells, menus, buttons
    xs-plus:  length,   //  11.5px
    sm:       length,   //  12px
    sm-plus:  length,   //  12.5px
    base:     length,   //  13px   — app default
    md:       length,   //  13.5px — conn-name
    lg:       length,   //  14px   — section + page headings
    xl:       length,   //  16px
    xxl:      length,   //  20px
    xxxl:     length,   //  28px   — connections-title
    display:  length,   //  56px   — brand-name (weight 600)
}

// ─── Font weights ────────────────────────────────────────────────────────────
export struct FontWeights {
    normal:   int,   // 400
    medium:   int,   // 500
    semibold: int,   // 600
    bold:     int,   // 700
}

// ─── Letter spacing ─────────────────────────────────────────────────────────
// Original values are in em; converted to px at base font size (13px).
// Scale proportionally when used with other font sizes.
export struct LetterSpacings {
    tightest: length,   // -0.04em → -0.52px — brand wordmark
    tighter:  length,   // -0.025em → -0.33px
    tight:    length,   // -0.01em → -0.13px
    normal:   length,   //  0
    wide:     length,   //  0.01em →  0.13px
    wider:    length,   //  0.04em →  0.52px
    eyebrow:  length,   //  0.08em →  1.04px — section heads
    label:    length,   //  0.10em →  1.30px — sidebar eyebrows
}

// ─── Border radii ────────────────────────────────────────────────────────────
export struct BorderRadii {
    none: length,   //     0
    xs:   length,   //  3px — checkbox
    sm:   length,   //  4px — kbd, tiny chips
    md:   length,   //  6px — DEFAULT / --radius-sm
    lg:   length,   //  8px — inputs, buttons
    xl:   length,   // 10px — --radius (cards)
    xxl:  length,   // 14px — --radius-lg (modals, quick-connect)
    full: length,   // 9999px — pill shape
}

// ─── Border widths ───────────────────────────────────────────────────────────
export struct BorderWidths {
    none:   length,   // 0
    thin:   length,   // 1px — DEFAULT
    medium: length,   // 2px
}

// ─── Spacing ─────────────────────────────────────────────────────────────────
// Fixed-size chrome dimensions and IDE-specific spacing anchors.
export struct AppSpacing {
    xxs:         length,   //  1px  — 0.25 (hairline gaps)
    xs:          length,   //  3px  — 0.75
    sm:          length,   //  5px  — 1.25
    md:          length,   //  7px  — 1.75
    lg:          length,   //  9px  — 2.25
    xl:          length,   // 13px  — 3.25  (form field padding-x)
    xxl:         length,   // 18px  — 4.5
    titlebar:    length,   // 44px
    tab:         length,   // 32px
    sidebar:     length,   // 240px
    gutter:      length,   // 44px
}

// ─── Animation durations ─────────────────────────────────────────────────────
export struct AnimationDurations {
    micro:   duration,   // 120ms — micro press
    fast:    duration,   // 160ms
    normal:  duration,   // 180ms — DEFAULT, standard hover
    medium:  duration,   // 250ms
    slow:    duration,   // 350ms — dock resize
    enter:   duration,   // 450ms — page enter
    stagger: duration,   // 500ms — row stagger
}

// ─── Layout global ──────────────────────────────────────────────────────────
// Single source of truth for all non-color tokens. Access from any component:
//
//   import { Layout } from "themes/layout.slint";
//
//   Text {
//       font-family:    Layout.font.sans;
//       font-size:      Layout.text.base;
//       font-weight:    Layout.weight.medium;
//       letter-spacing: Layout.tracking.eyebrow;
//   }
//   Rectangle {
//       border-radius: Layout.radius.lg;
//       border-width:  Layout.border.thin;
//   }
//   animate x { duration: Layout.duration.normal; }
//
export global Layout {
    // ── Typography ────────────────────────────────────────────────────────────
    out property <FontFamilies> font: {
        sans: "Inter",
        mono: "JetBrains Mono",
    };

    out property <FontSizes> text: {
        xxs:      10px,
        micro:    10.5px,
        xs:       11px,
        xs-plus:  11.5px,
        sm:       12px,
        sm-plus:  12.5px,
        base:     13px,
        md:       13.5px,
        lg:       14px,
        xl:       16px,
        xxl:      20px,
        xxxl:     28px,
        display:  56px,
    };

    out property <FontWeights> weight: {
        normal:   400,
        medium:   500,
        semibold: 600,
        bold:     700,
    };

    out property <LetterSpacings> tracking: {
        tightest: -0.52px,
        tighter:  -0.33px,
        tight:    -0.13px,
        normal:    0px,
        wide:      0.13px,
        wider:     0.52px,
        eyebrow:   1.04px,
        label:     1.30px,
    };

    // ── Borders ───────────────────────────────────────────────────────────────
    out property <BorderRadii> radius: {
        none: 0px,
        xs:   3px,
        sm:   4px,
        md:   6px,
        lg:   8px,
        xl:   10px,
        xxl:  14px,
        full: 9999px,
    };

    out property <BorderWidths> border: {
        none:   0px,
        thin:   1px,
        medium: 2px,
    };

    // ── Spacing ───────────────────────────────────────────────────────────────
    out property <AppSpacing> spacing: {
        xxs:         1px,
        xs:          3px,
        sm:          5px,
        md:          7px,
        lg:          9px,
        xl:          13px,
        xxl:         18px,
        titlebar:    44px,
        tab:         32px,
        sidebar:     240px,
        gutter:      44px,
    };

    // ── Motion ────────────────────────────────────────────────────────────────
    out property <AnimationDurations> duration: {
        micro:   120ms,
        fast:    160ms,
        normal:  180ms,
        medium:  250ms,
        slow:    350ms,
        enter:   450ms,
        stagger: 500ms,
    };
}

// ─── Tokens not representable in Slint ───────────────────────────────────────
//
// The following tailwind.config.js sections have no direct Slint equivalent
// and must be handled inline or through platform-specific code:
//
//   boxShadow            Slint has drop-shadow on Image/Text only, no inset
//                        or stacked shadows. Use Rectangle opacity layers
//                        to approximate elevation.
//
//   transitionTiming     easing is only usable inline in `animate` blocks:
//                          out-soft: cubic-bezier(0.2, 0.7, 0.2, 1)
//                          in-soft:  cubic-bezier(0.8, 0, 0.8, 0.3)
//
//   backgroundImage      Slint uses @linear-gradient / @radial-gradient on
//                        brush-typed properties (background, border-color).
//
//   backdropBlur         not available in Slint
//
//   zIndex               Slint uses declaration order for stacking
//
//   keyframes/animation  Slint uses property-based `animate` blocks, not
//                        named keyframe sequences
