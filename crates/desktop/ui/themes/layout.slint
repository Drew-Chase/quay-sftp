import "..\..\fonts\inter\Inter-LightItalic.ttf";
import "..\..\fonts\inter\Inter-Medium.ttf";
import "..\..\fonts\inter\Inter-MediumItalic.ttf";
import "..\..\fonts\inter\Inter-Regular.ttf";
import "..\..\fonts\inter\Inter-SemiBold.ttf";
import "..\..\fonts\inter\Inter-SemiBoldItalic.ttf";
