import "..\..\fonts\jetbrains mono\JetBrainsMono-ExtraBoldItalic.ttf";
import "..\..\fonts\jetbrains mono\JetBrainsMono-ExtraLight.ttf";
import "..\..\fonts\jetbrains mono\JetBrainsMono-ExtraLightItalic.ttf";
import "..\..\fonts\jetbrains mono\JetBrainsMono-Italic.ttf";
import "..\..\fonts\jetbrains mono\JetBrainsMono-Light.ttf";
import "..\..\fonts\jetbrains mono\JetBrainsMono-LightItalic.ttf";
import "..\..\fonts\jetbrains mono\JetBrainsMono-Medium.ttf";
import "..\..\fonts\jetbrains mono\JetBrainsMono-MediumItalic.ttf";
import "..\..\fonts\jetbrains mono\JetBrainsMono-Regular.ttf";
import "..\..\fonts\jetbrains mono\JetBrainsMono-SemiBold.ttf";
import "..\..\fonts\jetbrains mono\JetBrainsMono-SemiBoldItalic.ttf";
import "..\..\fonts\jetbrains mono\JetBrainsMono-Thin.ttf";
import "..\..\fonts\jetbrains mono\JetBrainsMono-ThinItalic.ttf";
import "..\..\fonts\inter\Inter-Black.ttf";
import "..\..\fonts\inter\Inter-BlackItalic.ttf";
import "..\..\fonts\inter\Inter-Bold.ttf";
import "..\..\fonts\inter\Inter-BoldItalic.ttf";
import "..\..\fonts\inter\Inter-ExtraBold.ttf";
import "..\..\fonts\inter\Inter-ExtraBoldItalic.ttf";
