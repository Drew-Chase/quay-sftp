import { ColorPalette } from "color_palette.slint";
import { DarkTheme } from "dark.slint";
import { LightTheme } from "light.slint";

export { ColorPalette }

export global Theme {
    // Set to false to switch to the light theme.
    in-out property <bool> dark-mode: true;

    out property <ColorPalette> palette: dark-mode ? DarkTheme.palette : LightTheme.palette;
}
