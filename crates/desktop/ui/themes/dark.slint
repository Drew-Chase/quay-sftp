import {
    ColorPalette,
    SurfaceColors, InkColors, HairlineColors,
    AccentColors, SemanticColors,
    TagColors, TagSwatch,
    FiletypeColors, FiletypeSwatch, FiletypeFolderSwatch,
    SyntaxColors, TrafficColors,
    HeroColors, ContentColors, ContentSwatch, ColorScale, UiSwatch,
} from "color_palette.slint";

// ─── Dark Theme ───────────────────────────────────────────────────────────────
// All values sourced from tailwind.config.js + the HeroUI plugin block.
// oklch → sRGB conversions are anchored on the HeroUI hex values where exact
// equivalents are declared; remaining values are perceptually extrapolated.
export global DarkTheme {
    out property <ColorPalette> palette: {
        // ── Canvas + elevation ────────────────────────────────────────────────
        surface: {
            base:   #000000,   // bg
            level0: #050505,   // surface.0
            level1: #0b0b0c,   // surface.1 / content1
            level2: #131316,   // surface.2 / content2
            level3: #1a1a1e,   // surface.3 / content3
            level4: #242429,   // content4
        },

        // ── Text ramp ─────────────────────────────────────────────────────────
        ink: {
            ink01:   #f6f7f9,   // ink.1 / foreground
            ink02: #aeb1b8,   // ink.2
            ink03:  #6b6e76,   // ink.3
            ink04:  #45474d,   // ink.4
        },

        // ── Hairlines / dividers ──────────────────────────────────────────────
        hairline: {
            subtle: #ffffff0f,   // rgba(255,255,255,0.06)
            strong: #ffffff1f,   // rgba(255,255,255,0.12)
        },

        // ── Brand accent — sky blue ───────────────────────────────────────────
        // oklch(0.78 0.15 230) confirmed as #21c8ff via heroui primary.DEFAULT
        accent: {
            base: #21c8ff,   // oklch(0.78 0.15 230)
            soft: #21c8ff29, // oklch(0.78 0.15 230 / 0.16)
            glow: #21c8ff59, // oklch(0.78 0.15 230 / 0.35)
            ink:  #001a2c,   // accent.ink — text on accent bg
        },

        // ── Semantic status ───────────────────────────────────────────────────
        // All confirmed via heroui success / warning / danger / secondary
        semantic: {
            ok:     #59d38c,   // oklch(0.78 0.15 155) — heroui success
            warn:   #f7b83d,   // oklch(0.82 0.15  80) — heroui warning
            danger: #ff5f5b,   // oklch(0.74 0.17   5) — heroui danger
            violet: #ae89ff,   // oklch(0.72 0.18 295) — heroui secondary
            pink:   #ff6070,   // oklch(0.74 0.17   5) — decorative, ~danger hue
        },

        // ── Environment tag pills ─────────────────────────────────────────────
        tag: {
            prod: { bg: #200f08, border: #52200e, fg: #e07840 },   // oklch(…/…/25)
            stag: { bg: #1c1a00, border: #4a4200, fg: #e8ca40 },   // oklch(…/…/80)
            dev:  { bg: #001a10, border: #00401e, fg: #68e8a0 },   // oklch(…/…/155)
        },

        // ── File-type icon swatches ───────────────────────────────────────────
        filetype: {
            folder: { gradient-from: #0d2c3e, gradient-to: #091520, fg: #7ad4f8 },   // oklch(0.32/0.18/0.85 @ 230)
            js:     { bg: #272300, fg: #e8db28 },   // hue  90 — yellow
            ts:     { bg: #0a1438, fg: #92b4ff },   // hue 240 — blue
            py:     { bg: #002818, fg: #68f0a8 },   // hue 155 — green
            rb:     { bg: #2a1200, fg: #ffb468 },   // hue  25 — orange
            json:   { bg: #201e00, fg: #ddd050 },   // hue  50 — muted yellow  (C=0.10)
            img:    { bg: #1c0832, fg: #cca0ff },   // hue 295 — purple
            zip:    { bg: #1e1e00, fg: #d8d450 },   // hue  60 — muted yellow  (C=0.12)
            env:    { bg: #280808, fg: #ff9090 },   // hue   0 — red
            yml:    { bg: #281008, fg: #ff9888 },   // hue   5 — red
            sh:     { bg: #082010, fg: #90e080 },   // hue 130 — muted green   (C=0.12)
            sql:    { bg: #120e28, fg: #c0b0f0 },   // hue 270 — muted purple  (C=0.12)
        },

        // ── Syntax highlighting ───────────────────────────────────────────────
        syntax: {
            keyword:    #c0a0ff,   // oklch(0.78 0.18 295) — violet, lighter than secondary
            func:       #7ad4f8,   // oklch(0.85 0.15 230) — lighter sky blue
            string-lit: #d8cc60,   // oklch(0.85 0.15  90) — bright yellow
            number:     #ffb870,   // oklch(0.85 0.15  25) — bright orange
            comment:    #45474d,   // ink.4 (exact)
            operator:   #aeb1b8,   // ink.2 (exact)
            prop:       #70e8a8,   // oklch(0.85 0.15 155) — bright green
            typename:   #7ad4f8,   // oklch(0.85 0.15 230) — same as func
            tag:        #e87878,   // oklch(0.80 0.18   5) — bright red/pink
        },

        // ── macOS traffic lights ──────────────────────────────────────────────
        traffic: {
            red:    #ff5f57,   // brand-locked exact value
            yellow: #febc2e,   // brand-locked exact value
            green:  #28c840,   // brand-locked exact value
        },

        // ── HeroUI semantic colors ────────────────────────────────────────────
        // Exact values from the heroui() plugin block in tailwind.config.js.
        hero: {
            background: #000000,
            foreground: #f6f7f9,
            focus:      #21c8ff,
            divider:    #ffffff0f,   // rgba(255,255,255,0.06)

            content: {
                c1: { bg: #0b0b0c, fg: #f6f7f9 },   // content1
                c2: { bg: #131316, fg: #aeb1b8 },   // content2
                c3: { bg: #1a1a1e, fg: #6b6e76 },   // content3
                c4: { bg: #242429, fg: #45474d },   // content4
            },

            neutral: {
                base: #1a1a1e,   // default.DEFAULT
                fg:   #f6f7f9,   // default.foreground
                c50:  #050505,
                c100: #0b0b0c,
                c200: #131316,
                c300: #1a1a1e,
                c400: #45474d,
                c500: #6b6e76,
                c600: #aeb1b8,
                c700: #d1d3d8,
                c800: #e8e9ec,
                c900: #f6f7f9,
            },

            primary: {
                base: #21c8ff,   // primary.DEFAULT
                fg:   #001a2c,   // primary.foreground
                c50:  #03141a,
                c100: #052029,
                c200: #08303d,
                c300: #0c4659,
                c400: #116480,
                c500: #21c8ff,
                c600: #00b4f0,
                c700: #009ed8,
                c800: #007eb7,
                c900: #005187,
            },

            secondary: { base: #ae89ff, fg: #ffffff },
            success:   { base: #59d38c, fg: #ffffff },
            warning:   { base: #f7b83d, fg: #000000 },
            danger:    { base: #ff5f5b, fg: #ffffff },
        },
    };
}
